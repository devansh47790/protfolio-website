# Copy this file to .env.local and fill in the values.
# .env.local is gitignored.

# ---- Sanity (frontend reads) ----
# Get these from sanity.io/manage after creating a project.
VITE_SANITY_PROJECT_ID=2gm1jzpw
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-10-01

# ---- Sanity (migration script only) ----
# Generate a write-token at sanity.io/manage > API > Tokens.
# Used only by scripts/migrate-to-sanity.mjs. Never commit this.
SANITY_PROJECT_ID=2gm1jzpw
SANITY_DATASET=production
SANITY_TOKEN=cp .env.example .env.local
